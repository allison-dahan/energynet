{
  "name": "energynet-theme",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "bs": "browser-sync start --config bs.config.cjs",
    "start": "node -e \"require('child_process').spawn('npm',['run','dev'],{stdio:'inherit',shell:true}); require('child_process').spawn('npm',['run','bs'],{stdio:'inherit',shell:true});\""
  },
  "devDependencies": {
    "browser-sync": "^3.0.4",
    "sass": "^1.77.0",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "@maptiler/leaflet-maptilersdk": "^4.1.1",
    "@maptiler/sdk": "^4.0.1",
    "leaflet": "^1.9.4"
  }
}
